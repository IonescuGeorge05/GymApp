<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/25.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.MainController"
            prefWidth="400" prefHeight="800"
            stylesheets="@style.css">

    <!-- StackPane pentru conținutul tab-urilor -->
    <StackPane fx:id="contentStack" prefWidth="400" prefHeight="750" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <AnchorPane fx:id="profileAnchor" styleClass="tab-content"/>
        <AnchorPane fx:id="classesAnchor" styleClass="tab-content"/>
        <AnchorPane fx:id="statsAnchor" styleClass="tab-content"/>
        <AnchorPane fx:id="aiAnchor" styleClass="tab-content"/>
    </StackPane>

    <!-- Bara tab-urilor jos, butoane spațiate egal -->
    <HBox spacing="10" prefHeight="60" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0"
          style="-fx-background-color: #1e1e2f;">

        <Button fx:id="btnProfile" text="Profile" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="tab-button"/>
        <Button fx:id="btnClasses" text="Classes" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="tab-button"/>
        <Button fx:id="btnStats" text="Stats" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="tab-button"/>
        <Button fx:id="btnAI" text="AI" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="tab-button"/>
    </HBox>

</AnchorPane>
